# --------------------------------------------------
# Default: normalize all text files to LF
# --------------------------------------------------
* text=auto eol=lf

# --------------------------------------------------
# Explicit text file types (force LF)
# --------------------------------------------------
*.c      text eol=lf
*.cpp    text eol=lf
*.h      text eol=lf
*.hpp    text eol=lf
*.ino    text eol=lf

*.py     text eol=lf
*.sh     text eol=lf
*.bat    text eol=lf

*.cmake  text eol=lf
CMakeLists.txt text eol=lf

*.txt    text eol=lf
*.md     text eol=lf
*.json   text eol=lf
*.yml    text eol=lf
*.yaml   text eol=lf
*.ini    text eol=lf

# --------------------------------------------------
# PlatformIO / embedded specific
# --------------------------------------------------
*.ld     text eol=lf
*.csv    text eol=lf

# --------------------------------------------------
# Binary files (NEVER modify)
# --------------------------------------------------
*.png    binary
*.jpg    binary
*.jpeg   binary
*.gif    binary
*.bmp    binary
*.ico    binary

*.zip    binary
*.tar    binary
*.gz     binary
*.7z     binary

*.pdf    binary

*.elf    binary
*.bin    binary
*.hex    binary
*.map    binary

*.a      binary
*.so     binary
*.dll    binary
*.exe    binary

# --------------------------------------------------
# Optional: treat everything unknown as binary-safe
# (commented out, enable if you want stricter control)
# --------------------------------------------------
# * -text